# Copy this file to ".env" and adjust the values.
# Compose reads .env for variable substitution, and the web/worker
# containers receive these as environment variables.

# --- Application ---
APP_NAME=Price Monitor
APP_SECRET=please-change-this-to-a-long-random-string
TIMEZONE=UTC

# --- Web ---
WEB_PORT=8000

# --- Database ---
# DB_HOST must be the compose service name ("db") when running in Docker.
DB_DRIVER=mysql+pymysql
DB_HOST=db
DB_PORT=3306
DB_NAME=pricemon
DB_USER=pricemon
DB_PASSWORD=pricemon
DB_ROOT_PASSWORD=change-this-root-password

# Host port to expose MySQL on (debugging only).
DB_PORT_HOST=3306
